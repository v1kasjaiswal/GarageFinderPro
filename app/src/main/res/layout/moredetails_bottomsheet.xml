<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent">

    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/detailsCoverImage"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            android:src="@drawable/blank"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardView8"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="end"
            android:layout_marginRight="20dp"
            android:layout_marginTop="-50dp"
            app:cardCornerRadius="50dp"
            app:cardElevation="5dp">

            <ImageView
                android:id="@+id/detailsOwnerImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/blank" />

        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/detailsGarageName"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:layout_marginTop="-35dp"
            android:fontFamily="@font/archivo"
            android:text="Your Garage Name!"
            android:textColor="@color/offline"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/detailsGarageTiming"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Timing: 9:00 - 22:00"
            android:textSize="15sp"
            android:layout_marginStart="15dp"
            android:textColor="@color/grey"
            android:fontFamily="@font/archivo"/>

        <TextView
            android:id="@+id/detailsGarageTowing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Towing Service: Available"
            android:textSize="15sp"
            android:layout_marginStart="15dp"
            android:textColor="@color/grey"
            android:fontFamily="@font/archivo"/>


        <TextView
            android:id="@+id/detailsGarageStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Open"
            android:textSize="15sp"
            android:layout_gravity="end"
            android:layout_marginTop="-15dp"
            android:layout_marginEnd="20dp"
            android:textColor="@color/grey"
            android:fontFamily="@font/archivo"/>

        <TextView
            android:id="@+id/detailsGarageMinCost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Min. Service Cost: ₹500 - ₹1000"
            android:textSize="15sp"
            android:layout_marginStart="15dp"
            android:textColor="@color/grey"
            android:fontFamily="@font/archivo"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact Details: "
            android:textSize="20sp"
            android:layout_marginTop="7dp"
            android:layout_marginStart="15dp"
            android:textColor="@color/offline"
            android:fontFamily="@font/archivo"/>


        <Button
            android:id="@+id/detailsGarageCall1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/black"
            android:fontFamily="@font/archivo"
            android:layout_marginLeft="10dp"
            android:paddingRight="50dp"
            android:paddingLeft="50dp"
            android:text="Call No. 1"
            android:textColor="@color/white"
            android:textSize="15sp" />

        <Button
            android:id="@+id/detailsGarageCall2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-48dp"
            android:backgroundTint="@color/black"
            android:fontFamily="@font/archivo"
            android:layout_gravity="end"
            android:layout_marginRight="10dp"
            android:paddingRight="50dp"
            android:paddingLeft="50dp"
            android:text="Call No. 2"
            android:textColor="@color/white"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Get Directions: "
            android:textSize="20sp"
            android:layout_marginTop="7dp"
            android:layout_marginStart="15dp"
            android:textColor="@color/offline"
            android:fontFamily="@font/archivo"/>

        <Button
            android:id="@+id/getGoogleMaps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:backgroundTint="@color/black"
            android:fontFamily="@font/archivo"
            android:paddingLeft="40dp"
            android:paddingRight="40dp"
            android:text="Google Maps"
            android:textColor="@color/white"
            android:textSize="15sp" />

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-48dp"
            android:backgroundTint="@color/black"
            android:fontFamily="@font/archivo"
            android:layout_gravity="end"
            android:layout_marginRight="10dp"
            android:paddingRight="45dp"
            android:paddingLeft="45dp"
            android:text="MapBox UI"
            android:textColor="@color/white"
            android:textSize="15sp" />

        <TextView
        android:id="@+id/textView20"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:fontFamily="@font/archivo"
        android:layout_marginLeft="15dp"
        android:text="Garage Showcase Images"
        android:textColor="@color/offline"
        android:textSize="20sp" />

    <LinearLayout
        android:id="@+id/linearLayout2"
        android:layout_width="match_parent"
        android:layout_height="155dp"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"
        android:orientation="horizontal">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">


                <androidx.cardview.widget.CardView
                    android:layout_width="300dp"
                    android:layout_height="150dp"
                    android:layout_marginRight="10dp"
                    android:background="@color/white"
                    android:elevation="8dp"
                    app:cardCornerRadius="15dp">

                    <ImageView
                        android:id="@+id/banner1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/blank" />

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="300dp"
                    android:layout_height="150dp"
                    android:layout_marginRight="10dp"
                    android:background="@color/white"
                    android:elevation="8dp"
                    app:cardCornerRadius="15dp">

                    <ImageView
                        android:id="@+id/banner2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/blank" />

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="300dp"
                    android:layout_height="150dp"
                    android:layout_marginRight="10dp"
                    android:background="@color/white"
                    android:elevation="8dp"
                    app:cardCornerRadius="15dp">

                    <ImageView
                        android:id="@+id/banner3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/blank" />

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="300dp"
                    android:layout_height="150dp"
                    android:layout_marginRight="10dp"
                    android:background="@color/white"
                    android:elevation="8dp"
                    app:cardCornerRadius="15dp">

                    <ImageView
                        android:id="@+id/banner4"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/blank" />

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="300dp"
                    android:layout_height="150dp"
                    android:layout_marginRight="10dp"
                    android:background="@color/white"
                    android:elevation="8dp"
                    app:cardCornerRadius="15dp">

                    <ImageView
                        android:id="@+id/banner5"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/blank" />

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="300dp"
                    android:layout_height="150dp"
                    android:layout_marginRight="10dp"
                    android:background="@color/white"
                    android:elevation="8dp"
                    app:cardCornerRadius="15dp">

                    <ImageView
                        android:id="@+id/banner6"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/blank" />

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="300dp"
                    android:layout_height="150dp"
                    android:background="@color/white"
                    android:elevation="8dp"
                    app:cardCornerRadius="15dp">

                    <ImageView
                        android:id="@+id/banner7"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/blank" />

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </HorizontalScrollView>

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/archivo"
        android:layout_marginLeft="15dp"
        android:text="Garage Specialization"
        android:textColor="@color/offline"
        android:textSize="20sp" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardView10"
        android:layout_width="match_parent"
        android:layout_height="210dp"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="5dp"
        android:layout_marginRight="15dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="@color/grey2">

        <TextView
            android:id="@+id/detailsSpecialization1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="15dp"
            android:ellipsize="marquee"
            android:fontFamily="@font/archivo"
            android:marqueeRepeatLimit="marquee_forever"
            android:singleLine="true"
            android:text="◆  Specialization 1"
            android:textColor="@color/offline"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/detailsSpecialization2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="52dp"
            android:ellipsize="marquee"
            android:fontFamily="@font/archivo"
            android:marqueeRepeatLimit="marquee_forever"
            android:singleLine="true"
            android:text="◆  Specialization 2"
            android:textColor="@color/offline"
            android:textSize="20dp" />

        <TextView
            android:id="@+id/detailsSpecialization3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="90dp"
            android:ellipsize="marquee"
            android:fontFamily="@font/archivo"
            android:marqueeRepeatLimit="marquee_forever"
            android:singleLine="true"
            android:text="◆  Specialization 3"
            android:textColor="@color/offline"
            android:textSize="20dp" />

        <TextView
            android:id="@+id/detailsSpecialization4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="130dp"
            android:ellipsize="marquee"
            android:fontFamily="@font/archivo"
            android:marqueeRepeatLimit="marquee_forever"
            android:singleLine="true"
            android:text="◆  Specialization 4"
            android:textColor="@color/offline"
            android:textSize="20dp" />


        <TextView
            android:id="@+id/detailsSpecialization5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="170dp"
            android:layout_marginBottom="15dp"
            android:ellipsize="marquee"
            android:fontFamily="@font/archivo"
            android:marqueeRepeatLimit="marquee_forever"
            android:singleLine="true"
            android:text="◆  Specialization 5"
            android:textColor="@color/offline"
            android:textSize="20dp" />

    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/textView17"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:fontFamily="@font/archivo"
        android:text="Ratings Overview"
        android:layout_gravity="center_horizontal"
        android:textColor="@color/offline"
        android:textSize="20sp" />

    <RatingBar
        android:id="@+id/detailsRatingBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:elevation="0dp"
        android:isIndicator="true"
        android:layout_gravity="center_horizontal"
        android:numStars="5"
        android:progressTint="@color/offline"
        android:rating="4.5" />

    <TextView
        android:id="@+id/textView18"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/archivo"
        android:text="Reviews"
        android:layout_marginLeft="15dp"
        android:textColor="@color/offline"
        android:textSize="20sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/detailsReviewsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="5dp"
        android:layout_marginTop="5dp" />

        <TextView
        android:layout_width="wrap_content"
        android:layout_height="23dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="5dp"
        android:fontFamily="@font/archivo"
        android:text="@string/branding"
        android:textColor="@color/grey"
        android:textSize="15sp"
        android:layout_gravity="center_horizontal" />

    </LinearLayout>

    </androidx.core.widget.NestedScrollView>
</LinearLayout>