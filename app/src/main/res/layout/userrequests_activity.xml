<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    tools:context=".OwnerRequestsJobsActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Requests Sent"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="5dp"
        android:fontFamily="@font/archivo"
        android:textSize="20dp"
        android:textColor="@color/offline"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Request Status: "
        android:layout_marginLeft="20dp"
        android:layout_marginBottom="5dp"
        android:fontFamily="@font/archivo"
        android:textSize="15dp"
        android:textColor="@color/offline"/>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        app:hintAnimationEnabled="true"
        app:startIconDrawable="@drawable/garage">

        <AutoCompleteTextView
            android:id="@+id/requestedStatus"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="@font/archivo"
            android:inputType="none"
            android:text="Request Status Type"
            android:textColor="@color/offline"
            android:textSize="20dp" />
    </com.google.android.material.textfield.TextInputLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/userRequestsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="610dp"
        android:layout_marginTop="5dp"/>

</LinearLayout>